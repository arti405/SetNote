<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Quick Create"
        android:textStyle="bold"
        android:textSize="18sp"
        android:paddingBottom="12dp"/>

    <Button
        android:id="@+id/actionStartSession"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Start Session"/>

    <Button
        android:id="@+id/actionCreateNote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Create Note"/>

    <Button
        android:id="@+id/actionCreateTemplate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Create Template"/>

    <Button
        android:id="@+id/actionStartEmptySession"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Start empty session"/>

    <Button
        android:id="@+id/actionStartFromTemplate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Start from template"/>

    <Button
        android:id="@+id/actionManageTemplates"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Templates (later)"/>

    <Button
        android:id="@+id/actionNewCollection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="New collection"/>

</LinearLayout>